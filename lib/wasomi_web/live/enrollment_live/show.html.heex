<.header>
  Enrollment {@enrollment.id}
  <:subtitle>This is a enrollment record from your database.</:subtitle>
  <:actions>
    <.link patch={~p"/enrollments/#{@enrollment}/show/edit"} phx-click={JS.push_focus()}>
      <.button>Edit enrollment</.button>
    </.link>
  </:actions>
</.header>

<.list>
  <:item title="Status">{@enrollment.status}</:item>
  <:item title="Enrolled at">{@enrollment.enrolled_at}</:item>
  <:item title="Activated at">{@enrollment.activated_at}</:item>
</.list>

<.back navigate={~p"/enrollments"}>Back to enrollments</.back>

<.modal
  :if={@live_action == :edit}
  id="enrollment-modal"
  show
  on_cancel={JS.patch(~p"/enrollments/#{@enrollment}")}
>
  <.live_component
    module={WasomiWeb.EnrollmentLive.FormComponent}
    id={@enrollment.id}
    title={@page_title}
    action={@live_action}
    enrollment={@enrollment}
    patch={~p"/enrollments/#{@enrollment}"}
  />
</.modal>
